{
  "version": "1.0",
  "description": "Machine-readable guide for SiteKit block variant matching and new-variant decisions.",
  "decisionRules": {
    "patternExistsWhen": [
      "type exists in the SiteKit block registry",
      "variant exists for that block type",
      "required layoutMode or navLayout exists when specified",
      "the source structure matches the renderer composition, not just the styling"
    ],
    "needsNewVariantWhen": [
      "the source needs a fundamentally different composition",
      "the source needs interaction or behavior not present in the current renderer",
      "the source needs a new tile topology, stage pattern, or information architecture",
      "the source cannot be described honestly by any existing type/variant/layoutMode combination"
    ],
    "doesNotNeedNewVariantWhen": [
      "only colors change",
      "only border, radius, or shadow changes",
      "copy density changes but the composition stays the same",
      "left-right emphasis can already be handled by the current block"
    ]
  },
  "blocks": {
    "header": {
      "builderEditable": true,
      "layoutKeys": ["navLayout"],
      "variants": [
        {"id": 1, "summary": "classic horizontal nav", "useWhen": ["brand left", "links right", "standard site navigation"], "builderEditable": true},
        {"id": 2, "summary": "center-weighted nav with softer CTA", "useWhen": ["centered feel", "quiet CTA", "balanced nav bar"], "builderEditable": true},
        {"id": 3, "summary": "brand plus tagline emphasis", "useWhen": ["tagline visible under brand", "brand voice matters"], "builderEditable": true},
        {"id": 4, "summary": "centered desktop navigation", "useWhen": ["centered nav set", "menu-first desktop header"], "builderEditable": true},
